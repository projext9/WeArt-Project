<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace = "we.are.travelers.member">

	<insert id="joinMember" parameterType="memberVo">
		insert into member(member_idx,member_id,member_pwd,member_name,
		member_nickname,member_phone,member_grade,member_ip,
		social_sns_token,social_reg_code,social_naver,social_facebook,social_google,social_kakao,
		member_regdate,member_delyn) 
		
		 values(#{member_id}, #{member_pwd}, #{member_name}, #{member_nickname},#{member_phone},#{member_grade},
		 #{member_ip},#{social_sns_token},#{social_reg_code},#{social_reg_code},#{social_reg_code},#{social_naver},#{social_facebook},#{social_kakao}
		 ,#{member_regdate},#{member_delyn})
	</insert>
	
	<!-- <select id="loginMember" parameterType="memberVo" resultType="map">
		select count(*) as member_auth, member_grade from member where member_id=#{member_id} and member_pw=#{member_pw}
	</select> -->
	
	<select id="loginMember" parameterType="map" resultType="map">
		select count(*) as member_auth, member_grade from member where member_id=#{member_id} and member_pw=#{member_pwd}
	</select>
	
	<select id="getMemberInfo" parameterType="string" resultType="memberVo">
		select member_id, member_name, member_pwd, member_phone from member where member_id=#{member_id}
	</select>

	<select id="checkId" parameterType="string" resultType="int">
		select count(*) from member where member_id=#{member_id}
	</select>


</mapper>